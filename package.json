    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "^1.53.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "git-cliff": "^2.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
