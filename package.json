    "antd": "^6.3.7",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.46.0",
    "immer": "^11.1.4",
    "jotai": "^2.19.1",
    "jotai-immer": "^0.4.3",
    "openapi-fetch": "^0.17.0",
    "overlay-kit": "^1.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
