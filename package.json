    "antd": "^6.4.3",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.46.1",
    "immer": "^11.1.8",
    "jotai": "^2.20.0",
    "jotai-immer": "^0.4.3",
    "openapi-fetch": "^0.17.0",
    "overlay-kit": "^1.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
