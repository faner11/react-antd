    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-oxlint": "^1.62.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "git-cliff": "^2.13.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
